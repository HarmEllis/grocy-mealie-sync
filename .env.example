# Grocy
GROCY_URL=http://grocy:9283
GROCY_API_KEY=your-grocy-api-key

# Mealie
MEALIE_URL=http://mealie:9925
MEALIE_API_TOKEN=your-mealie-bearer-token

# Optional and not recommended: ignore invalid/untrusted TLS certificates for all outbound HTTPS requests
# (for example Grocy, Mealie, Healthchecks, and generic webhooks).
# Prefer fixing trust properly via NODE_EXTRA_CA_CERTS instead.
# ALLOW_INSECURE_TLS=false

# Sync Settings
POLL_INTERVAL_SECONDS=60
PRODUCT_SYNC_INTERVAL_HOURS=6
# Mealie shopping list ID for products that are under the min_stock_amount in Grocy (optional — can also be set in the web UI)
# MEALIE_SHOPPING_LIST_ID=uuid-of-target-shopping-list
# Grocy unit ID for newly created products (optional — can also be set in the web UI)
# GROCY_DEFAULT_UNIT_ID=3
# Automatically create unmatched Mealie products in Grocy (optional — can also be set in the web UI)
# AUTO_CREATE_PRODUCTS=true
# Automatically create unmatched Mealie units in Grocy (optional — can also be set in the web UI)
# AUTO_CREATE_UNITS=true
# During Grocy→Mealie polls, actively recreate missing unchecked list items for products that are still below minimum stock (optional — can also be set in the web UI)
# ENSURE_LOW_STOCK_ON_MEALIE_LIST=true
# During Grocy→Mealie polls, sync Mealie's "In possession" state from Grocy stock for all mapped products (optional — can also be set in the web UI)
# SYNC_MEALIE_IN_POSSESSION=true
# Only mark a Mealie food as "In possession" when current stock is strictly greater than min_stock_amount (optional — can also be set in the web UI)
# MEALIE_IN_POSSESSION_ONLY_ABOVE_MIN_STOCK=true
# Step size used by the Mapping Wizard min stock input (optional — can also be set in the web UI, allowed: 1, 0.1, 0.01, default: 1)
# MAPPING_WIZARD_MIN_STOCK_STEP=1
# Only add stock in Grocy for products that have min_stock_amount > 0 (optional — can also be set in the web UI)
# STOCK_ONLY_MIN_STOCK=true
# Global Healthchecks.io ping URL for scheduler runs (optional). Success pings go to this URL; partial/failure pings go to <url>/fail.
# HEALTHCHECKS_PING_URL=https://hc-ping.com/your-uuid
# Generic webhook URL for scheduler run notifications (optional)
# NOTIFICATION_WEBHOOK_URL=https://example.com/hooks/grocy-mealie-sync
# Generic webhook mode: "errors_only" (default) or "always"
# NOTIFICATION_WEBHOOK_MODE=errors_only

# Database
DATABASE_PATH=./data/sync.db

# Security
# Optional: Enable app authentication explicitly. When unset, auth is enabled automatically when AUTH_SECRET is set.
# AUTH_ENABLED=true
# Shared secret for the web login and Authorization: Bearer <token> API access.
# Set AUTH_ENABLED=false to disable auth even when AUTH_SECRET is still present.
# AUTH_SECRET=your-secret-token-here

# Postgres (used by Mealie in compose-dev.yml)
# Generate a strong random password, e.g.: openssl rand -base64 32
# POSTGRES_PASSWORD=change-me-to-a-random-password
